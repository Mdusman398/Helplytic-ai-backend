<html>
  <head>
    <meta charset="UTF-8" />
    <title>Activate Your Helplytics AI Account</title>
  </head>
  <body style="margin:0; padding:0; background-color:#F5F5F0; font-family:'Inter', Arial, sans-serif;">
    <table align="center" width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center" style="padding: 40px 0;">
          <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:32px; padding:48px; box-shadow:0 20px 40px rgba(0,0,0,0.04); border: 1px solid #E5E7EB;">
            <!-- Header -->
            <tr>
              <td align="center">
                <div style="width:48px; height:48px; background-color:#0D8E8E; border-radius:12px; margin-bottom:24px; display:inline-block;">
                    <span style="color:white; font-size:24px; font-weight:bold; line-height:48px;">H</span>
                </div>
                <h1 style="color:#131C1C; font-size:28px; font-weight:800; margin:0 0 12px 0; letter-spacing:-0.02em;">Activate Your Signal</h1>
                <p style="color:#6B7280; font-size:16px; line-height:1.5; margin:0;">Welcome to Helplytics AI. To begin connecting with mentors and sharing problems, please verify your email.</p>
              </td>
            </tr>

            <!-- Divider -->
            <tr>
              <td style="padding: 32px 0;">
                <hr style="border:none; border-top:1px solid #F3F4F6;" />
              </td>
            </tr>

            <!-- Button -->
            <tr>
              <td align="center">
                <a href="{{verifyLink}}" style="display:inline-block; padding:18px 42px; background-color:#0D8E8E; color:#ffffff; text-decoration:none; border-radius:16px; font-size:16px; font-weight:700; shadow: 0 10px 15px -3px rgba(13, 142, 142, 0.2);">
                  Verify My Account
                </a>
              </td>
            </tr>

            <!-- Link Fallback -->
            <tr>
              <td align="center" style="padding-top:24px;">
                <p style="font-size:12px; color:#9CA3AF; margin-bottom:8px;">Button not working? Copy this link:</p>
                <a href="{{verifyLink}}" style="font-size:13px; color:#0D8E8E; text-decoration:none; word-break:break-all; font-weight:500;">
                  {{verifyLink}}
                </a>
              </td>
            </tr>

            <!-- Footer Info -->
            <tr>
              <td align="center" style="padding-top:48px;">
                <p style="color:#9CA3AF; font-size:13px; margin-bottom:8px;">
                  This link expires in 24 hours.
                </p>
                <p style="color:#D1D5DB; font-size:12px; margin:0;">
                  If you didn't create this account, you can safely ignore this email.
                </p>
              </td>
            </tr>
          </table>

          <!-- Brand Footer -->
          <table width="600" cellpadding="0" cellspacing="0" style="margin-top:24px;">
            <tr>
              <td align="center" style="font-size:12px; color:#9CA3AF; font-weight:500;">
                © 2026 Helplytics AI Platform. All rights reserved.
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>